#!/usr/bin/env bash
# migration-harness — orchestrates a goose-based code migration.
#
# Usage:
#   migration-harness init                          # one-time setup
#   migration-harness <repo> "<migration request>"  # run full pipeline
#   migration-harness status                        # show last run summary
#   migration-harness resume                        # resume the last incomplete run
#   migration-harness step <name> <repo> ...        # run a single step (advanced)

set -euo pipefail

# Resolve install location (follows symlinks portably)
_resolve_link() {
  local f="$1"
  while [[ -L "$f" ]]; do
    local dir; dir="$(cd "$(dirname "$f")" && pwd -P)"
    f="$(readlink "$f")"
    [[ "$f" != /* ]] && f="$dir/$f"   # relative symlink
  done
  echo "$f"
}
SELF="$(_resolve_link "${BASH_SOURCE[0]}")"
MH_INSTALL_DIR="$(cd "$(dirname "$SELF")/.." && pwd -P)"
export MH_INSTALL_DIR

# shellcheck source=lib/common.sh
source "$MH_INSTALL_DIR/lib/common.sh"
source "$MH_INSTALL_DIR/lib/metrics.sh"
source "$MH_INSTALL_DIR/lib/step-detect.sh"
source "$MH_INSTALL_DIR/lib/step-plan.sh"
source "$MH_INSTALL_DIR/lib/step-execute.sh"
source "$MH_INSTALL_DIR/lib/step-verify.sh"
source "$MH_INSTALL_DIR/lib/step-fix-loop.sh"

usage() {
  cat >&2 <<EOF
migration-harness — goose-driven code migration

Usage:
  migration-harness init                          one-time configuration
  migration-harness <repo> "<migration request>"  run full pipeline
  migration-harness status                        show summary of last run
  migration-harness resume                        resume the last run
  migration-harness step <step> <repo> [...]      run single step (plan|execute|verify|fix)

Examples:
  migration-harness init
  migration-harness ~/code/coolstore "Migrate this Java EE app to Quarkus 3"
  migration-harness ~/code/legacy-api "Express.js to FastAPI, keep REST endpoints"

Config: $MH_CONFIG
Runs:   $MH_RUNS/
EOF
  exit "${1:-1}"
}

cmd_init() {
  header "migration-harness — first-time setup"
  check_deps

  echo
  info "This will save your config to $MH_CONFIG"

  # ── Auto-detect from goose config ──
  local goose_config="$HOME/.config/goose/config.yaml"
  local detected_provider="" detected_model=""
  if [[ -f "$goose_config" ]]; then
    detected_provider=$(grep '^GOOSE_PROVIDER:' "$goose_config" 2>/dev/null | awk '{print $2}' || true)
    detected_model=$(grep '^GOOSE_MODEL:' "$goose_config" 2>/dev/null | awk '{print $2}' || true)
  fi

  if [[ -n "$detected_provider" && -n "$detected_model" ]]; then
    echo
    ok "Detected from goose config: provider=$detected_provider model=$detected_model"
    read -rp "Use these settings? [Y/n]: " use_detected
    if [[ "${use_detected:-y}" =~ ^[Yy]$ ]]; then
      MH_PROVIDER="$detected_provider"
      MH_MODEL="$detected_model"
    fi
  fi

  # ── Manual entry if not auto-detected ──
  if [[ -z "${MH_PROVIDER:-}" ]]; then
    echo
    echo "Select your Goose provider:"
    select prov in "anthropic" "openai" "google" "gcp_vertex_ai" "ollama" "other"; do
      [[ -n "$prov" ]] && break
    done
    MH_PROVIDER="$prov"
  fi

  if [[ -z "${MH_MODEL:-}" ]]; then
    local default_model=""
    case "$MH_PROVIDER" in
      anthropic|gcp_vertex_ai) default_model="claude-sonnet-4-5" ;;
      openai)    default_model="gpt-4o" ;;
      google)    default_model="gemini-2.0-flash" ;;
      ollama)    default_model="llama3.1:70b" ;;
    esac
    read -rp "Model name [$default_model]: " MH_MODEL
    MH_MODEL="${MH_MODEL:-$default_model}"
    [[ -n "$MH_MODEL" ]] || fatal "Model name required"
  fi

  # Limits
  read -rp "Max turns per goose invocation [200]: " MH_MAX_TURNS
  MH_MAX_TURNS="${MH_MAX_TURNS:-200}"
  read -rp "Max fix-loop iterations [3]: " MH_MAX_FIX_ITERATIONS
  MH_MAX_FIX_ITERATIONS="${MH_MAX_FIX_ITERATIONS:-3}"

  save_config

  # Verify goose itself is configured
  if ! goose configure --list 2>/dev/null | grep -q "$MH_PROVIDER" 2>/dev/null; then
    warn "Goose itself may not be configured for '$MH_PROVIDER'."
    warn "Run: goose configure"
  fi

  echo
  ok "Saved $MH_CONFIG"
  ok "Ready. Run:  migration-harness <repo> \"<migration request>\""
}

cmd_run() {
  local repo="$1"
  local request="$2"
  load_config
  check_deps

  [[ -d "$repo" ]] || fatal "repo not found: $repo"
  repo="$(cd "$repo" && pwd)"

  local repo_name
  repo_name="$(basename "$repo")"

  RUN_DIR="$(new_run_dir "$repo_name")"
  export RUN_DIR
  ok "Run directory: $RUN_DIR"

  # Persist the original invocation for resume
  jq -n --arg repo "$repo" --arg request "$request" \
    '{repo:$repo, request:$request, started_at:now|todate}' \
    > "$RUN_DIR/invocation.json"

  header "Step 1/5 — Detect"
  track_step_start "detect"
  if step_detect "$repo"; then
    track_step_end "detect" "success"
  else
    track_step_end "detect" "failed"
    fatal "Detect step failed"
  fi

  header "Step 2/5 — Plan (human approval gate)"
  track_step_start "plan"
  if step_plan "$repo" "$request"; then
    track_step_end "plan" "success"
  else
    track_step_end "plan" "failed"
    fatal "Plan step failed or rejected"
  fi

  header "Step 3/5 — Execute"
  track_step_start "execute"
  if step_execute "$repo"; then
    track_step_end "execute" "success"
  else
    track_step_end "execute" "failed"
    warn "Execute step had failures"
  fi

  header "Step 4/5 — Verify"
  track_step_start "verify"
  local verify_status=0
  if step_verify "$repo" "$RUN_DIR/verify.json"; then
    track_step_end "verify" "success"
  else
    verify_status=$?
    track_step_end "verify" "failed"
  fi

  header "Step 5/5 — Fix-loop (conditional)"
  track_step_start "fix_loop"
  if step_fix_loop "$repo"; then
    track_step_end "fix_loop" "success"
    ok "Migration complete. Build clean."
  else
    track_step_end "fix_loop" "failed"
    warn "Migration finished with errors. Inspect $RUN_DIR/ for details."
  fi

  echo
  info "Generating metrics..."
  local metrics_file
  metrics_file=$(generate_metrics "$repo" "$request")
  ok "Metrics: $metrics_file"

  echo
  info "Copying artifacts to repo for evaluation..."
  cp "$metrics_file" "$repo/metrics.json" 2>/dev/null || warn "Could not copy metrics.json to repo"
  cp "$RUN_DIR/detect.json" "$repo/detect.json" 2>/dev/null || true
  cp "$RUN_DIR/graph.json" "$repo/graph.json" 2>/dev/null || true
  ok "Artifacts copied to $repo/"

  echo
  info "Run artifacts in $RUN_DIR/"
  info "Repo artifacts in $repo/ (metrics.json, PLAN.md, execution-log.md, etc.)"
}

cmd_status() {
  load_config
  local d
  d="$(latest_run_dir)" || fatal "No runs found in $MH_RUNS"
  [[ -n "$d" ]] || fatal "No runs found"
  RUN_DIR="$d"

  header "Last run: $(basename "$d")"
  [[ -f "$d/invocation.json" ]] && jq -r '"  Repo:    \(.repo)\n  Request: \(.request)\n  Started: \(.started_at)"' "$d/invocation.json"
  echo
  if [[ -f "$d/plan.json" ]]; then
    local total ok_count
    total=$(jq -r '.items | length' "$d/plan.json")
    ok_count=$(find "$d" -name 'item-*.json' -exec jq -r 'select(.status=="ok") | .n' {} \; 2>/dev/null | wc -l | tr -d ' ')
    info "  Items: $ok_count / $total complete"
  fi
  if [[ -f "$d/verify-1.json" ]]; then
    local latest_verify
    latest_verify=$(ls -1t "$d"/verify-*.json 2>/dev/null | head -1)
    info "  Last verify: $(jq -r '"build_ok=\(.build_ok) errors=\((.errors // []) | length)"' "$latest_verify")"
  fi
}

cmd_resume() {
  load_config
  local d
  d="$(latest_run_dir)" || fatal "No runs found in $MH_RUNS"
  [[ -n "$d" ]] || fatal "No runs found"
  RUN_DIR="$d"
  export RUN_DIR

  [[ -f "$d/invocation.json" ]] || fatal "Run $d has no invocation.json"
  [[ -f "$d/plan.json" ]]       || fatal "Run $d has no plan.json — re-run from start"

  local repo
  repo=$(jq -r '.repo' "$d/invocation.json")

  ok "Resuming run $(basename "$d") on $repo"
  # Skip detect + plan; execute will skip already-done items naturally
  header "Step 3/5 — Execute (resume)"
  step_execute "$repo"
  header "Step 4/5 — Verify"
  step_verify "$repo" "$RUN_DIR/verify.json" || true
  header "Step 5/5 — Fix-loop (conditional)"
  step_fix_loop "$repo" || warn "Finished with errors"
}

cmd_step() {
  local step="$1"; shift
  load_config
  check_deps

  # Single-step runs use the latest run dir unless a fresh one is desired.
  RUN_DIR="$(latest_run_dir)" || fatal "No run dir — run the full pipeline first"
  export RUN_DIR

  case "$step" in
    detect)   step_detect "$@" ;;
    plan)     step_plan "$@" ;;
    execute)  step_execute "$@" ;;
    verify)   step_verify "$1" "$RUN_DIR/verify-manual.json" ;;
    fix)      step_fix_loop "$@" ;;
    *)        fatal "Unknown step: $step (detect|plan|execute|verify|fix)" ;;
  esac
}

# ── Dispatch ─────────────────────────────────────────────────────
[[ $# -ge 1 ]] || usage 1

case "$1" in
  init)     shift; cmd_init "$@" ;;
  status)   shift; cmd_status "$@" ;;
  resume)   shift; cmd_resume "$@" ;;
  step)     shift; cmd_step "$@" ;;
  -h|--help|help) usage 0 ;;
  *)
    [[ $# -eq 2 ]] || usage 1
    cmd_run "$1" "$2"
    ;;
esac
