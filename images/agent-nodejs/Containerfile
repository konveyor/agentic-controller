# agent-nodejs: Node.js agent image. Adds Node.js and npm on top of agent-base.
#
# Build context must be the repository root:
#   podman build -t agent-nodejs -f images/agent-nodejs/Containerfile .

FROM quay.io/konveyor/agent-base:latest AS base

USER root

RUN dnf install -y nodejs npm && dnf clean all

USER harness

ENTRYPOINT ["migration-harness"]
CMD ["run"]
